platform :ios, '15.1'

target 'NosmaiDetectorDemo' do
  # Nosmai Moderation SDK — ships the NosmaiDetection.xcframework and its
  # encrypted models. Register a project at https://nosmai.com/ for a license key.
  pod 'NosmaiModerationSDK', '~> 1.0'
end

# Agora is added separately as a Swift Package (AgoraRtcEngine_iOS); Xcode
# resolves it on open. No CocoaPods entry is needed for Agora.

# Xcode 15+ sandboxes run-script phases by default, which blocks the CocoaPods
# resource-copy phase (the encrypted models). Disable it on the app target.
post_install do |installer|
  installer.aggregate_targets.each do |aggregate|
    aggregate.user_project.native_targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      end
    end
    aggregate.user_project.save
  end
end
